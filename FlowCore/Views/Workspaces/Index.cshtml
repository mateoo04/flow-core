@model IReadOnlyList<WorkspaceListRow>
@{
    ViewData["Title"] = "Workspaces";
}
<h1 class="text-3xl font-bold tracking-tight text-fg">Workspaces</h1>
<p class="mt-2 text-fg-secondary">Browse delivery workspaces and their projects.</p>

<div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    @foreach (var row in Model)
    {
        <a asp-controller="Workspaces" asp-action="Details" asp-route-id="@row.Id"
           class="group rounded-xl border border-fg-muted/10 bg-card p-5 shadow-card transition-colors duration-150 hover:border-brand/30 hover:bg-raised focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand">
            <h2 class="text-lg font-semibold text-fg group-hover:text-fg">@row.Name</h2>
            <div class="mt-3 flex flex-wrap gap-2 text-xs">
                <span class="rounded-full bg-raised px-2.5 py-0.5 text-fg-secondary">@row.Visibility</span>
                <span class="rounded-full bg-raised px-2.5 py-0.5 text-fg-muted">@row.ProjectCount projects</span>
            </div>
        </a>
    }
</div>
