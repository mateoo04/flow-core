@model IReadOnlyList<TaskStatusDefinitionListRow>
@inject FlowCore.Repositories.IProjectRepository ProjectRepo
@{
    ViewData["Title"] = "Task statuses";
}
<h1 class="text-3xl font-bold tracking-tight text-fg">Task statuses</h1>
<p class="mt-2 text-fg-secondary">Per-project workflow columns (definitions).</p>

<div class="mt-8 space-y-10">
    @foreach (var group in Model.GroupBy(r => r.ProjectId).OrderBy(g => ProjectRepo.GetById(g.Key)?.Key ?? ""))
    {
        var proj = ProjectRepo.GetById(group.Key);
        <section>
            <h2 class="flex flex-wrap items-center gap-2 text-lg font-semibold text-fg">
                @if (proj is not null)
                {
                    <a class="rounded text-brand outline-none hover:text-fg focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-app" asp-controller="Projects" asp-action="Details" asp-route-id="@proj.Id">@proj.Key</a>
                    <span class="text-fg-muted font-normal">— @proj.Name</span>
                }
                else
                {
                    <span class="font-mono text-sm text-fg-muted">@group.Key</span>
                }
            </h2>
            <div class="mt-4 flex flex-col gap-2">
                @foreach (var row in group.OrderBy(r => r.Position))
                {
                    <a asp-controller="TaskStatusDefinitions" asp-action="Details" asp-route-id="@row.Id"
                       class="flex items-center gap-3 rounded-xl border border-fg-muted/10 bg-card px-4 py-3 shadow-card outline-none transition-colors duration-150 hover:border-brand/30 hover:bg-raised focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-app">
                        <span class="h-3 w-3 shrink-0 rounded-full border border-fg-muted/30" style="background-color: @row.ColorHex" aria-hidden="true"></span>
                        <div class="flex-1">
                            <span class="font-medium text-fg">@row.Name</span>
                            <span class="ml-2 text-xs text-fg-muted">pos @row.Position</span>
                        </div>
                        @if (row.IsDoneState)
                        {
                            <span class="rounded bg-success/15 px-2 py-0.5 text-xs text-success">Done</span>
                        }
                    </a>
                }
            </div>
        </section>
    }
</div>
