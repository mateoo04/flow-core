@model FlowCore.Models.BoardColumn
@{
    ViewData["Title"] = Model.Name;
}
<h1 class="text-2xl font-bold text-fg">@Model.Name</h1>
<dl class="mt-6 grid gap-3 text-sm sm:grid-cols-[8rem_1fr]">
    <dt class="text-fg-muted">Board</dt>
    <dd>
        <a class="rounded text-brand outline-none hover:text-fg focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-app" asp-controller="Boards" asp-action="Details" asp-route-id="@Model.BoardId">Open board</a>
    </dd>
    <dt class="text-fg-muted">WIP limit</dt><dd class="text-fg-secondary">@Model.WipLimit</dd>
    <dt class="text-fg-muted">Tasks</dt>
    <dd>
        <ul class="m-0 list-none space-y-2 p-0">
            @foreach (var t in Model.Tasks.OrderBy(x => x.Title))
            {
                <li>
                    <a class="block rounded-lg border border-fg-muted/15 px-3 py-2 text-brand outline-none transition-colors hover:border-brand/40 hover:bg-raised focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-app"
                       asp-controller="Tasks" asp-action="Details" asp-route-id="@t.Id">@t.Title</a>
                </li>
            }
        </ul>
    </dd>
</dl>
