@model IReadOnlyList<BoardColumnListRow>
@{
    ViewData["Title"] = "Board columns";
}
<h1 class="text-3xl font-bold tracking-tight text-fg">Board columns</h1>
<p class="mt-2 text-fg-secondary">Columns on all boards.</p>

<div class="mt-6 overflow-hidden rounded-xl border border-fg-muted/15 shadow-card">
    <table class="w-full border-collapse text-left text-sm">
        <thead class="bg-raised/60 text-xs font-semibold uppercase tracking-wide text-fg-muted">
        <tr>
            <th class="px-4 py-3" scope="col">Name</th>
            <th class="px-4 py-3" scope="col">Pos</th>
            <th class="px-4 py-3" scope="col">Tasks</th>
            <th class="px-4 py-3" scope="col">Done</th>
            <th class="px-4 py-3" scope="col">Board</th>
        </tr>
        </thead>
        <tbody class="divide-y divide-fg-muted/10 bg-card">
        @foreach (var row in Model)
        {
            <tr class="transition-colors duration-150 hover:bg-raised/40">
                <td class="px-4 py-3">
                    <a class="rounded font-medium text-brand outline-none hover:text-fg focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-card" asp-controller="BoardColumns" asp-action="Details" asp-route-id="@row.Id">@row.Name</a>
                </td>
                <td class="px-4 py-3 tabular-nums text-fg-muted">@row.Position</td>
                <td class="px-4 py-3 tabular-nums text-fg-secondary">@row.TaskCount</td>
                <td class="px-4 py-3 text-fg-muted">@(row.IsDoneColumn ? "Yes" : "")</td>
                <td class="px-4 py-3">
                    <a class="rounded text-brand outline-none hover:text-fg focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-card"
                       asp-controller="Boards" asp-action="Details" asp-route-id="@row.BoardId"
                       aria-label="Open board for column @row.Name">Open board</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
