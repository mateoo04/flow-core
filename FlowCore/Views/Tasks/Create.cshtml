@model TaskCreateFormVm
@inject FlowCore.Services.UiText T
@{
    ViewData["Title"] = T["crud.tasks.create_title"];
    var project = ViewBag.Project as Project;
    var board = ViewBag.Board as Board;
    var statuses = ViewBag.Statuses as IReadOnlyList<TaskStatusDefinition> ?? Array.Empty<TaskStatusDefinition>();
    if (project is null || board is null)
    {
        throw new InvalidOperationException("Project and board are required.");
    }
}
<h1 class="font-headline text-3xl font-extrabold tracking-tight text-fg">@T["crud.tasks.create_title"]</h1>
<p class="mt-2 text-sm font-medium text-fg-secondary">@project.Name — @board.Name</p>
@if (Model.ParentTaskItemId is { } pid)
{
    <p class="mt-2 text-sm text-fg-muted">Parent task ID: <span class="font-mono">@pid</span></p>
}
<form method="post" asp-action="Create" class="mt-8 max-w-xl space-y-5">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ProjectId"/>
    <input type="hidden" asp-for="BoardId"/>
    <input type="hidden" asp-for="ParentTaskItemId"/>
    <div asp-validation-summary="All" class="text-sm text-[var(--color-error)]"></div>
    <div>
        <label asp-for="Title" class="block text-sm font-medium text-fg-secondary">Title</label>
        <input asp-for="Title" class="mt-1 w-full rounded-xl border border-border bg-[var(--color-surface)] px-3 py-2 text-fg focus:border-[var(--color-secondary)] focus:outline-none focus:ring-1 focus:ring-[var(--color-secondary)]" required/>
    </div>
    <div>
        <label asp-for="Description" class="block text-sm font-medium text-fg-secondary">Description</label>
        <textarea asp-for="Description" rows="4" class="mt-1 w-full rounded-xl border border-border bg-[var(--color-surface)] px-3 py-2 text-fg focus:border-[var(--color-secondary)] focus:outline-none focus:ring-1 focus:ring-[var(--color-secondary)]"></textarea>
    </div>
    <div>
        <label asp-for="TaskStatusDefinitionId" class="block text-sm font-medium text-fg-secondary">Status</label>
        <select asp-for="TaskStatusDefinitionId" class="mt-1 w-full rounded-xl border border-border bg-[var(--color-surface)] px-3 py-2 text-fg focus:border-[var(--color-secondary)] focus:outline-none focus:ring-1 focus:ring-[var(--color-secondary)]">
            @foreach (var s in statuses.OrderBy(x => x.Position))
            {
                <option value="@s.Id">@s.Name</option>
            }
        </select>
    </div>
    <div>
        <label asp-for="Priority" class="block text-sm font-medium text-fg-secondary">Priority</label>
        <select asp-for="Priority" asp-items="Html.GetEnumSelectList<TaskPriority>()" class="mt-1 w-full rounded-xl border border-border bg-[var(--color-surface)] px-3 py-2 text-fg focus:border-[var(--color-secondary)] focus:outline-none focus:ring-1 focus:ring-[var(--color-secondary)]"></select>
    </div>
    <div>
        <label asp-for="StoryPoints" class="block text-sm font-medium text-fg-secondary">Story points</label>
        <input asp-for="StoryPoints" type="number" min="0" class="mt-1 w-full rounded-xl border border-border bg-[var(--color-surface)] px-3 py-2 text-fg focus:border-[var(--color-secondary)] focus:outline-none focus:ring-1 focus:ring-[var(--color-secondary)]"/>
    </div>
    <div>
        <label asp-for="DueDate" class="block text-sm font-medium text-fg-secondary">Due (optional)</label>
        <input asp-for="DueDate" type="date" class="mt-1 w-full rounded-xl border border-border bg-[var(--color-surface)] px-3 py-2 text-fg focus:border-[var(--color-secondary)] focus:outline-none focus:ring-1 focus:ring-[var(--color-secondary)]"/>
    </div>
    <div class="flex gap-3">
        <button type="submit" class="flex items-center gap-2 rounded-full bg-[var(--color-secondary)] px-4 py-2 text-sm font-semibold text-[var(--color-on-secondary)] shadow-sm transition-opacity hover:opacity-95">
            <span class="material-symbols-outlined text-[18px]" aria-hidden="true">add</span>
            @T["crud.tasks.create_submit"]
        </button>
        <a asp-controller="Projects" asp-action="Details" asp-route-id="@project.Id" asp-route-boardId="@board.Id" class="rounded-full border border-border bg-[var(--color-surface)] px-4 py-2 text-sm font-semibold text-fg transition-colors hover:bg-[var(--color-surface-container)]">Cancel</a>
    </div>
</form>
