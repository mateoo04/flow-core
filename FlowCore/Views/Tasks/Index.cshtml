@model IReadOnlyList<TaskListRow>
@{
    ViewData["Title"] = "Tasks";
}
<h1 class="text-2xl font-bold text-gray-900">Tasks</h1>
<table class="mt-4 w-full border-collapse border border-gray-200 text-left text-sm">
    <thead class="bg-gray-50">
    <tr>
        <th class="border-b border-gray-200 px-3 py-2">Title</th>
        <th class="border-b border-gray-200 px-3 py-2">Priority</th>
        <th class="border-b border-gray-200 px-3 py-2">Column</th>
        <th class="border-b border-gray-200 px-3 py-2">Parent</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var row in Model)
    {
        <tr class="border-b border-gray-100">
            <td class="px-3 py-2">
                <a class="text-indigo-600 hover:underline" asp-controller="Tasks" asp-action="Details" asp-route-id="@row.Id">@row.Title</a>
            </td>
            <td class="px-3 py-2">@row.Priority</td>
            <td class="px-3 py-2">
                <a class="text-indigo-600 hover:underline" asp-controller="BoardColumns" asp-action="Details" asp-route-id="@row.BoardColumnId">Column</a>
            </td>
            <td class="px-3 py-2">
                @if (row.ParentTaskItemId is { } pid)
                {
                    <a class="text-indigo-600 hover:underline" asp-controller="Tasks" asp-action="Details" asp-route-id="@pid">Parent</a>
                }
                else
                {
                    <span class="text-gray-400">—</span>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
