@model IReadOnlyList<TaskListRow>
@using FlowCore.Models
@{
    ViewData["Title"] = "Tasks";
}
<h1 class="text-3xl font-bold tracking-tight text-fg">Tasks</h1>
<p class="mt-2 text-fg-secondary">All tasks across boards. Subtasks are labeled.</p>

<ul class="m-0 mt-8 flex list-none flex-col gap-2 p-0">
    @foreach (var row in Model)
    {
        <li class="rounded-xl border border-fg-muted/10 bg-card shadow-card transition-colors duration-150 hover:border-brand/30 hover:bg-raised">
            <div class="flex items-start gap-4 px-4 py-3">
                <span class="mt-1.5 inline-block h-2 w-2 shrink-0 rounded-full @(row.Priority switch { TaskPriority.Urgent => "bg-danger", TaskPriority.High => "bg-brand-warn", TaskPriority.Medium => "bg-brand-accent", _ => "bg-fg-muted" })"
                      aria-hidden="true"></span>
                <div class="min-w-0 flex-1">
                    <a asp-controller="Tasks" asp-action="Details" asp-route-id="@row.Id"
                       class="block rounded-md font-medium text-fg outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-card">
                        @row.Title
                    </a>
                    <div class="mt-1 flex flex-wrap gap-3 text-xs text-fg-muted">
                        <span>@row.Priority</span>
                        <a class="rounded text-brand underline-offset-2 outline-none hover:text-fg focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-card"
                           asp-controller="BoardColumns" asp-action="Details" asp-route-id="@row.BoardColumnId">Open column</a>
                        @if (row.ParentTaskItemId is { } pid)
                        {
                            <a class="rounded text-brand underline-offset-2 outline-none hover:text-fg focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-card"
                               asp-controller="Tasks" asp-action="Details" asp-route-id="@pid">Open parent task</a>
                        }
                    </div>
                </div>
                <span class="text-fg-muted" aria-hidden="true">→</span>
            </div>
        </li>
    }
</ul>
