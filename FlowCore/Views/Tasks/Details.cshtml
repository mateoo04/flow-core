@model TaskItem
@using FlowCore.Models
@inject FlowCore.Repositories.IUserRepository UserRepo
@inject FlowCore.Services.UiText T
@{
    ViewData["Title"] = Model.Title;
    var project = Model.Board?.Project;
    var board = Model.Board;
}
<div class="lg:grid lg:grid-cols-3 lg:gap-8">
    <article class="lg:col-span-2">
        <header class="border-b border-fg-muted/15 pb-4">
            <div class="flex flex-wrap items-center gap-2 text-xs text-fg-muted">
                @if (Model.ParentTaskItemId is { } parentId)
                {
                    <span class="rounded bg-brand/15 px-2 py-0.5 text-brand">Subtask</span>
                }
                <span>@Model.Priority</span>
            </div>
            <h1 class="mt-2 text-3xl font-bold tracking-tight text-fg">@Model.Title</h1>
        </header>

        <div class="mt-6 space-y-6">
            <section>
                <h2 class="text-sm font-semibold uppercase tracking-wide text-fg-muted">Description</h2>
                <div class="mt-2 whitespace-pre-wrap text-fg-secondary leading-relaxed">@(string.IsNullOrWhiteSpace(Model.Description) ? "—" : Model.Description)</div>
            </section>

            @if (Model.ParentTaskItemId is { } pp)
            {
                <p class="text-sm">
                    <a class="rounded-lg border border-brand/30 px-3 py-2 font-medium text-brand outline-none transition-colors hover:bg-brand/10 focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-app"
                       asp-controller="Tasks" asp-action="Details" asp-route-id="@pp">Open parent task</a>
                </p>
            }

            <section>
                <h2 class="text-sm font-semibold uppercase tracking-wide text-fg-muted">Subtasks</h2>
                @if (project is not null && board is not null)
                {
                    <p class="mt-2">
                        <a class="inline-flex rounded-lg border border-brand/30 px-3 py-2 text-sm font-medium text-brand outline-none hover:bg-brand/10"
                           asp-controller="Tasks" asp-action="Create" asp-route-projectId="@project.Id" asp-route-boardId="@board.Id" asp-route-parentTaskItemId="@Model.Id">@T["crud.tasks.subtask_create"]</a>
                    </p>
                }
                @if (Model.Subtasks.Count > 0)
                {
                    <ul class="mt-3 space-y-2">
                        @foreach (var s in Model.Subtasks.OrderBy(x => x.Title))
                        {
                            <li>
                                <a asp-controller="Tasks" asp-action="Details" asp-route-id="@s.Id"
                                   class="flex items-center justify-between rounded-xl border border-fg-muted/10 bg-card px-4 py-3 text-sm outline-none transition-colors duration-150 hover:border-brand/30 hover:bg-raised focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-app">
                                    <span class="font-medium text-fg">@s.Title</span>
                                    <span class="text-fg-muted" aria-hidden="true">→</span>
                                </a>
                            </li>
                        }
                    </ul>
                }
            </section>

            <section>
                <h2 class="text-sm font-semibold uppercase tracking-wide text-fg-muted">Comments</h2>
                <form method="post" asp-action="AddComment" asp-route-id="@Model.Id" class="mt-4 space-y-2">
                    @Html.AntiForgeryToken()
                    <label class="sr-only" for="comment-body">@T["crud.tasks.add_comment"]</label>
                    <textarea id="comment-body" name="Body" rows="3" required
                              placeholder="@(T["crud.tasks.comment_placeholder"])"
                              class="w-full rounded-xl border border-fg-muted/20 bg-app px-3 py-2 text-sm text-fg"></textarea>
                    <button type="submit" class="flex items-center gap-2 rounded-full bg-[var(--color-secondary)] px-4 py-2 text-sm font-semibold text-[var(--color-on-secondary)] shadow-sm transition-opacity hover:opacity-95">
                        <span class="material-symbols-outlined text-[18px]" aria-hidden="true">send</span>
                        @T["crud.tasks.add_comment"]
                    </button>
                </form>
                @if (Model.Comments.Count > 0)
                {
                    <ul class="mt-6 space-y-4 border-l border-fg-muted/20 pl-4">
                        @foreach (var c in Model.Comments.OrderBy(x => x.CreatedAt))
                        {
                            var author = UserRepo.GetById(c.AuthorUserId)?.FullName ?? "User";
                            var initial = author.Length > 0 ? author[0] : '?';
                            <li class="relative">
                                <div class="absolute -left-[21px] top-1 flex h-6 w-6 items-center justify-center rounded-full bg-raised text-xs font-semibold text-fg-secondary" aria-hidden="true">@initial</div>
                                <div class="rounded-xl bg-card p-4 shadow-card">
                                    <div class="flex flex-wrap items-baseline justify-between gap-2 text-xs text-fg-muted">
                                        <span class="font-medium text-fg-secondary">@author</span>
                                        <time datetime="@c.CreatedAt.ToString("O")">@c.CreatedAt.ToString("g")</time>
                                    </div>
                                    <p class="mt-2 whitespace-pre-wrap text-sm text-fg-secondary">@c.Body</p>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </section>
        </div>

        @if (board is not null)
        {
            <p class="mt-10">
                <a class="inline-flex items-center rounded-xl border-2 border-brand px-4 py-2 text-sm font-semibold text-brand outline-none transition-colors hover:bg-brand/10 focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-app"
                   asp-controller="Boards" asp-action="Details" asp-route-id="@board.Id"><span aria-hidden="true">← </span>Back to board</a>
            </p>
        }
    </article>

    <aside class="mt-10 lg:mt-0">
        <div class="sticky top-6 rounded-xl bg-card p-5 shadow-card">
            <h2 class="text-xs font-semibold uppercase tracking-wide text-fg-muted">Details</h2>
            <dl class="mt-4 space-y-3 text-sm">
                <div>
                    <dt class="text-fg-muted">Status</dt>
                    <dd class="mt-0.5 text-fg">@(Model.TaskStatusDefinition?.Name ?? "—")</dd>
                </div>
                <div>
                    <dt class="text-fg-muted">Priority</dt>
                    <dd class="mt-0.5 text-fg">@Model.Priority</dd>
                </div>
                <div>
                    <dt class="text-fg-muted">Story points</dt>
                    <dd class="mt-0.5 text-fg">@Model.StoryPoints</dd>
                </div>
                @if (Model.DueDate is { } due)
                {
                    <div>
                        <dt class="text-fg-muted">Due</dt>
                        <dd class="mt-0.5 text-fg">@due.ToString("d")</dd>
                    </div>
                }
                @if (project is not null)
                {
                    <div>
                        <dt class="text-fg-muted">Project</dt>
                        <dd class="mt-0.5">
                            <a class="rounded text-brand outline-none hover:text-fg focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-card" asp-controller="Projects" asp-action="Details" asp-route-id="@project.Id">@project.Name</a>
                        </dd>
                    </div>
                }
                @if (Model.TaskTags.Count > 0)
                {
                    <div>
                        <dt class="text-fg-muted">Tags</dt>
                        <dd class="mt-0.5 flex flex-wrap gap-1.5">
                            @foreach (var tt in Model.TaskTags.OrderBy(x => x.Tag?.Name))
                            {
                                <a asp-controller="Tags" asp-action="Details" asp-route-id="@tt.TagId"
                                   class="rounded-full border border-fg-muted/20 bg-raised/80 px-2.5 py-0.5 text-xs font-medium text-brand outline-none transition-colors hover:border-brand/50 focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-card">#@(tt.Tag?.Name ?? "tag")</a>
                            }
                        </dd>
                    </div>
                }
            </dl>
            @if (project is not null)
            {
                <form method="post" asp-action="Delete" asp-route-id="@Model.Id" class="mt-6 border-t border-fg-muted/15 pt-4" onsubmit="return confirm('Delete this task and its subtasks?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="w-full rounded-lg border border-brand-warn/40 px-3 py-2 text-sm font-medium text-brand-warn hover:bg-brand-warn/10">@T["crud.tasks.delete"]</button>
                </form>
            }
        </div>
    </aside>
</div>
