@model MyWorkViewModel
@{
    ViewData["Title"] = "My work";
}
<h1 class="text-3xl font-bold tracking-tight text-fg">My work</h1>
<p class="mt-2 max-w-2xl text-fg-secondary">Tasks assigned to you, grouped by status. Signed in as <span class="font-medium text-fg">@Model.CurrentUserDisplayName</span> (demo).</p>

@if (Model.StatusGroups.Count == 0)
{
    <p class="mt-10 rounded-xl border border-dashed border-fg-muted/30 bg-card p-8 text-center text-fg-muted">No assigned tasks yet.</p>
}
else
{
    @for (var gi = 0; gi < Model.StatusGroups.Count; gi++)
    {
        var group = Model.StatusGroups[gi];
        var stripe = group.StatusColorHex ?? "#6366f1";
        var headingId = $"status-heading-{gi}";
        <section class="mt-10" aria-labelledby="@headingId">
            <div class="flex items-center gap-3 border-b border-fg-muted/15 pb-3">
                <span class="h-3 w-1 rounded-full" style="background-color: @stripe" aria-hidden="true"></span>
                <h2 id="@headingId" class="text-lg font-semibold text-fg">@group.StatusName</h2>
                <span class="text-sm tabular-nums text-fg-muted">@group.Tasks.Count</span>
            </div>
            <div class="mt-4 grid gap-3 sm:grid-cols-2">
                @foreach (var card in group.Tasks)
                {
                    <a asp-controller="Tasks" asp-action="Details" asp-route-id="@card.TaskId"
                       class="fc-task-avatar-ring fc-task-avatar-ring--card flex flex-col rounded-xl border border-fg-muted/10 bg-card p-4 text-left shadow-card transition-colors duration-150 hover:border-brand/30 hover:bg-raised focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
                       style="border-left: 3px solid @stripe">
                        <div class="line-clamp-2 font-medium text-fg">@card.Title</div>
                        <div class="mt-2 text-xs text-fg-muted">
                            <span class="text-fg-secondary">@card.ProjectName</span>
                        </div>
                        @if (card.Assignees.Shown.Count > 0 || card.Assignees.ExtraCount > 0)
                        {
                            <div class="mt-3 flex items-center justify-end gap-2 pt-3">
                                <span class="sr-only">Assignees</span>
                                <partial name="_AssigneeAvatarStack" model="card.Assignees"/>
                            </div>
                        }
                    </a>
                }
            </div>
        </section>
    }
}

<section class="mt-10 flex flex-wrap gap-x-4 gap-y-2 text-sm text-fg-muted" aria-label="Additional directory links">
    <span class="text-fg-secondary">More:</span>
    <a class="rounded text-brand outline-none transition-colors hover:text-fg focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-app" asp-controller="Users" asp-action="Index">Users</a>
    <a class="rounded text-brand outline-none transition-colors hover:text-fg focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-app" asp-controller="Tags" asp-action="Index">Tags</a>
    <a class="rounded text-brand outline-none transition-colors hover:text-fg focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-app" asp-controller="Boards" asp-action="Index">Boards</a>
    <a class="rounded text-brand outline-none transition-colors hover:text-fg focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-app" asp-controller="BoardColumns" asp-action="Index">Columns</a>
    <a class="rounded text-brand outline-none transition-colors hover:text-fg focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-app" asp-controller="TaskStatusDefinitions" asp-action="Index">Statuses</a>
    <a class="rounded text-brand outline-none transition-colors hover:text-fg focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-app" asp-controller="Comments" asp-action="Index">Comments</a>
</section>
