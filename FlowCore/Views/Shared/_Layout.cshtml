@using FlowCore.Repositories
@inject IWorkspaceRepository WorkspaceRepo
@inject IProjectRepository ProjectRepo
@{
    var workspaces = WorkspaceRepo.GetAll().ToList();
    var allProjects = ProjectRepo.GetAll().ToList();
    var activeWs = ViewData["ActiveWorkspaceId"] as Guid?;
    var activeProject = ViewData["ActiveProjectId"] as Guid?;
    var sidebarProjects = activeWs is { } w
        ? allProjects.Where(p => p.WorkspaceId == w).OrderBy(p => p.Name).Take(12).ToList()
        : allProjects.OrderBy(p => p.Name).Take(8).ToList();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <script>
        (function () {
            try {
                var k = 'flowcore-theme';
                var s = localStorage.getItem(k);
                var dark = s === 'dark' || (s !== 'light' && window.matchMedia('(prefers-color-scheme: dark)').matches);
                document.documentElement.classList.toggle('dark', dark);
            } catch (e) { /* ignore */ }
        })();
    </script>
    <title>@ViewData["Title"] - FlowCore</title>
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/FlowCore.styles.css" asp-append-version="true"/>
</head>
<body class="flex min-h-screen flex-col bg-app text-fg antialiased">
<a class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-card focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-fg focus:shadow-card focus:outline focus:outline-2 focus:outline-offset-2 focus:outline-brand"
   href="#main-content">Skip to main content</a>
<div class="flex min-h-screen flex-1">
    <aside class="flex w-64 shrink-0 flex-col border-r border-fg-muted/15 bg-card shadow-soft" aria-label="Site navigation">
        <div class="flex flex-col gap-3 border-b border-fg-muted/15 p-4">
            <div class="flex items-start justify-between gap-2">
                <div class="min-w-0">
                    <a class="rounded text-lg font-semibold tracking-tight text-fg no-underline outline-none transition-colors hover:text-brand focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-card"
                       asp-controller="Home" asp-action="Index">FlowCore</a>
                    <p class="mt-1 text-xs text-fg-muted">Org &amp; project delivery</p>
                </div>
                <button type="button"
                        id="theme-toggle"
                        class="shrink-0 rounded-lg p-2 text-fg-muted transition-colors hover:bg-raised hover:text-fg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
                        aria-label="Switch color theme"
                        aria-pressed="false">
                    <span class="sr-only">Toggle light / dark mode</span>
                    <svg class="h-5 w-5 dark:hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
                    </svg>
                    <svg class="hidden h-5 w-5 dark:block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
                    </svg>
                </button>
            </div>
        </div>

        <nav class="flex flex-1 flex-col gap-1 overflow-y-auto p-3 text-sm" aria-label="Main">
            <a class="rounded-lg px-3 py-2 font-medium text-fg-secondary transition-colors duration-150 hover:bg-raised hover:text-fg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "bg-raised text-fg" : "")"
               asp-controller="Home" asp-action="Index">Dashboard</a>

            <p class="mt-3 px-3 text-xs font-semibold uppercase tracking-wide text-fg-muted">Organizations</p>
            @foreach (var ws in workspaces)
            {
                var wsActive = activeWs == ws.Id;
                <a class="block rounded-lg border-l-2 py-2 pl-3 pr-2 text-fg-secondary transition-colors duration-150 hover:bg-raised hover:text-fg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand @(wsActive ? "border-brand bg-raised text-fg" : "border-transparent")"
                   asp-controller="Workspaces" asp-action="Details" asp-route-id="@ws.Id">@ws.Name</a>
            }
            <a class="mt-1 rounded-lg px-3 py-2 text-xs text-fg-muted transition-colors duration-150 hover:bg-raised hover:text-fg-secondary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
               asp-controller="Workspaces" asp-action="Index">All organizations…</a>

            <p class="mt-4 px-3 text-xs font-semibold uppercase tracking-wide text-fg-muted">Projects</p>
            <a class="rounded-lg px-3 py-2 text-fg-secondary transition-colors duration-150 hover:bg-raised hover:text-fg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand @(ViewContext.RouteData.Values["controller"]?.ToString() == "Projects" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "bg-raised text-fg" : "")"
               asp-controller="Projects" asp-action="Index">All projects</a>
            @foreach (var p in sidebarProjects)
            {
                var pActive = activeProject == p.Id;
                <a class="block min-w-0 truncate rounded-lg border-l-2 py-1.5 pl-3 pr-2 text-fg-secondary transition-colors duration-150 hover:bg-raised hover:text-fg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand @(pActive ? "border-brand bg-raised text-fg" : "border-transparent")"
                   asp-controller="Projects" asp-action="Details" asp-route-id="@p.Id"
                   title="@p.Name">@p.Name</a>
            }

            <p class="mt-4 px-3 text-xs font-semibold uppercase tracking-wide text-fg-muted">Core</p>
            <a class="rounded-lg px-3 py-2 text-fg-secondary transition-colors duration-150 hover:bg-raised hover:text-fg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tasks" ? "bg-raised text-fg" : "")"
               asp-controller="Tasks" asp-action="Index">Tasks</a>
            <a class="rounded-lg px-3 py-2 text-fg-secondary transition-colors duration-150 hover:bg-raised hover:text-fg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand @(ViewContext.RouteData.Values["controller"]?.ToString() == "Comments" ? "bg-raised text-fg" : "")"
               asp-controller="Comments" asp-action="Index">Comments</a>

            <details class="mt-4 rounded-lg border border-fg-muted/20 bg-app/50 open:bg-raised/30">
                <summary class="cursor-pointer list-none rounded-lg px-3 py-2 text-xs font-semibold uppercase tracking-wide text-fg-muted marker:content-none outline-none [&::-webkit-details-marker]:hidden focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand">
                    <span class="text-fg-secondary">More site sections</span>
                </summary>
                <div class="flex flex-col gap-0.5 border-t border-fg-muted/15 p-2">
                    <a class="rounded-md px-2 py-1.5 text-fg-muted transition-colors duration-150 hover:bg-card hover:text-fg-secondary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
                       asp-controller="Boards" asp-action="Index">Boards</a>
                    <a class="rounded-md px-2 py-1.5 text-fg-muted transition-colors duration-150 hover:bg-card hover:text-fg-secondary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
                       asp-controller="BoardColumns" asp-action="Index">Columns</a>
                    <a class="rounded-md px-2 py-1.5 text-fg-muted transition-colors duration-150 hover:bg-card hover:text-fg-secondary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
                       asp-controller="TaskStatusDefinitions" asp-action="Index">Statuses</a>
                    <a class="rounded-md px-2 py-1.5 text-fg-muted transition-colors duration-150 hover:bg-card hover:text-fg-secondary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
                       asp-controller="Users" asp-action="Index">Users</a>
                    <a class="rounded-md px-2 py-1.5 text-fg-muted transition-colors duration-150 hover:bg-card hover:text-fg-secondary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
                       asp-controller="Tags" asp-action="Index">Tags</a>
                </div>
            </details>
        </nav>

        <div class="mt-auto border-t border-fg-muted/15 p-3 text-xs text-fg-muted">
            <a class="rounded text-fg-secondary underline decoration-fg-muted/50 underline-offset-2 outline-none transition-colors hover:text-brand focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-card"
               asp-controller="Home" asp-action="Privacy">Privacy</a>
            <span class="text-fg-muted"> · </span>
            <span>&copy; 2026</span>
        </div>
    </aside>

    <div class="flex min-w-0 flex-1 flex-col">
        <main id="main-content" tabindex="-1" class="flex-1 px-4 py-6 sm:px-6 lg:px-8">
            <div class="mx-auto max-w-6xl">
                <partial name="_Breadcrumbs"/>
                @RenderBody()
            </div>
        </main>
    </div>
</div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
