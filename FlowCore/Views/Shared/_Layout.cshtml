<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - FlowCore</title>
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/FlowCore.styles.css" asp-append-version="true"/>
</head>
<body class="flex min-h-screen flex-col bg-white text-gray-900 antialiased">
<header class="border-b border-gray-200 bg-white">
    <nav class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4 px-4 py-3">
        <a class="text-lg font-semibold tracking-tight text-gray-900 no-underline hover:text-gray-600"
           asp-area="" asp-controller="Home" asp-action="Index">FlowCore</a>
        <ul class="m-0 flex list-none flex-wrap items-center gap-4 p-0 text-sm">
            <li>
                <a class="text-gray-600 no-underline hover:text-gray-900" asp-controller="Home" asp-action="Index">Dashboard</a>
            </li>
            <li>
                <a class="text-gray-600 no-underline hover:text-gray-900" asp-controller="Workspaces" asp-action="Index">Workspaces</a>
            </li>
            <li>
                <a class="text-gray-600 no-underline hover:text-gray-900" asp-controller="Projects" asp-action="Index">Projects</a>
            </li>
            <li>
                <a class="text-gray-600 no-underline hover:text-gray-900" asp-controller="Tasks" asp-action="Index">Tasks</a>
            </li>
            <li>
                <a class="text-gray-600 no-underline hover:text-gray-900" asp-controller="Users" asp-action="Index">Users</a>
            </li>
            <li>
                <a class="text-gray-600 no-underline hover:text-gray-900" asp-controller="Tags" asp-action="Index">Tags</a>
            </li>
            <li>
                <a class="text-gray-600 no-underline hover:text-gray-900" asp-controller="Boards" asp-action="Index">Boards</a>
            </li>
            <li>
                <a class="text-gray-600 no-underline hover:text-gray-900" asp-controller="BoardColumns" asp-action="Index">Columns</a>
            </li>
            <li>
                <a class="text-gray-600 no-underline hover:text-gray-900" asp-controller="TaskStatusDefinitions" asp-action="Index">Statuses</a>
            </li>
            <li>
                <a class="text-gray-600 no-underline hover:text-gray-900" asp-controller="Comments" asp-action="Index">Comments</a>
            </li>
            <li>
                <a class="text-gray-600 no-underline hover:text-gray-900" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </li>
        </ul>
    </nav>
</header>

<main class="flex flex-1 flex-col">
    <div class="mx-auto w-full max-w-5xl flex-1 px-4 py-8">
        <partial name="_Breadcrumbs"/>
        @RenderBody()
    </div>
</main>

<footer class="border-t border-gray-200 py-6 text-sm text-gray-500">
    <div class="mx-auto max-w-5xl px-4">
        &copy; 2026 - FlowCore —
        <a class="text-gray-600 underline decoration-gray-300 underline-offset-2 hover:text-gray-900"
           asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
