@using FlowCore.Models.ViewModels
@{
    var crumbs = ViewBag.Breadcrumbs as IReadOnlyList<BreadcrumbItem>;
}
@if (crumbs is { Count: > 0 })
{
    <nav aria-label="Breadcrumb" class="mb-6 text-sm text-fg-muted">
        <ol class="m-0 flex list-none flex-wrap items-center gap-2 p-0">
            @for (var i = 0; i < crumbs.Count; i++)
            {
                var c = crumbs[i];
                <li class="flex items-center gap-2">
                    @if (i > 0)
                    {
                        <span class="select-none text-fg-muted/40">/</span>
                    }
                    @if (c.Url is { } url)
                    {
                        <a class="text-brand no-underline transition-colors hover:text-fg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
                           href="@url">@c.Text</a>
                    }
                    else
                    {
                        <span class="font-medium text-fg-secondary" aria-current="page">@c.Text</span>
                    }
                </li>
            }
        </ol>
    </nav>
}
