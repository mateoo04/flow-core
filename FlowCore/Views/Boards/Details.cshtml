@model Board
@{
    ViewData["Title"] = Model.Name;
}
<h1 class="text-2xl font-bold text-gray-900">@Model.Name</h1>
<dl class="mt-4 grid gap-2 text-sm sm:grid-cols-[10rem_1fr]">
    <dt class="text-gray-500">Project</dt>
    <dd>
        <a class="text-indigo-600 hover:underline" asp-controller="Projects" asp-action="Details" asp-route-id="@Model.ProjectId">Open project</a>
    </dd>
    <dt class="text-gray-500">Columns</dt>
    <dd>
        <ul class="m-0 list-disc ps-5">
            @foreach (var col in Model.Columns.OrderBy(c => c.Position))
            {
                <li>
                    <a class="text-indigo-600 hover:underline" asp-controller="BoardColumns" asp-action="Details" asp-route-id="@col.Id">@col.Name</a>
                    <span class="text-gray-500">(@col.Tasks.Count.ToString()) tasks</span>
                </li>
            }
        </ul>
    </dd>
</dl>
