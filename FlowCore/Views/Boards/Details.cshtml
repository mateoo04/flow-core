@model Board
@{
    ViewData["Title"] = Model.Name;
}
<div class="flex flex-wrap items-start justify-between gap-4 border-b border-fg-muted/15 pb-4">
    <div>
        <h1 class="text-2xl font-bold tracking-tight text-fg">@Model.Name</h1>
        <p class="mt-1 text-sm text-fg-muted">
            <a class="text-brand hover:text-fg" asp-controller="Projects" asp-action="Details" asp-route-id="@Model.ProjectId">Project</a>
        </p>
    </div>
</div>

<p class="mt-4 text-sm text-fg-secondary">Scroll horizontally on small screens. Each card opens the task.</p>

<div class="mt-6 flex gap-4 overflow-x-auto pb-4">
    @foreach (var col in Model.Columns.OrderBy(c => c.Position))
    {
        <div class="flex w-72 shrink-0 flex-col rounded-xl bg-card shadow-card">
            <div class="border-b border-fg-muted/10 px-3 py-3">
                <div class="flex items-center justify-between gap-2">
                    <h2 class="font-semibold text-fg">@col.Name</h2>
                    <span class="tabular-nums text-xs text-fg-muted">@col.Tasks.Count</span>
                </div>
                @if (col.WipLimit > 0)
                {
                    <p class="mt-1 text-xs text-fg-muted">WIP @col.WipLimit</p>
                }
            </div>
            <div class="flex flex-1 flex-col gap-2 p-2">
                @if (col.Tasks.Count == 0)
                {
                    <p class="rounded-lg border border-dashed border-fg-muted/25 px-3 py-6 text-center text-xs text-fg-muted">No tasks in this column.</p>
                }
                else
                {
                    foreach (var task in col.Tasks.OrderBy(t => t.Title))
                    {
                        var stripe = task.TaskStatusDefinition?.ColorHex ?? "#6366f1";
                        <a asp-controller="Tasks" asp-action="Details" asp-route-id="@task.Id"
                           class="block rounded-lg border border-fg-muted/10 bg-app/80 p-3 text-left transition-colors duration-150 hover:border-brand/40 hover:bg-raised focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
                           style="border-left: 3px solid @stripe">
                            <div class="line-clamp-2 text-sm font-medium text-fg">@task.Title</div>
                            <div class="mt-2 flex flex-wrap items-center gap-2 text-xs text-fg-muted">
                                <span>@task.Priority</span>
                                @if (task.StoryPoints > 0)
                                {
                                    <span class="rounded bg-raised px-1.5 py-0.5 tabular-nums">@task.StoryPoints sp</span>
                                }
                                @if (task.ParentTaskItemId is not null)
                                {
                                    <span class="rounded bg-brand/10 px-1.5 py-0.5 text-brand">Subtask</span>
                                }
                            </div>
                        </a>
                    }
                }
            </div>
        </div>
    }
</div>

<p class="mt-6 text-sm text-fg-muted">Read-only demo — <span class="text-brand-warn">Add task</span> is intentionally disabled for the lab.</p>
