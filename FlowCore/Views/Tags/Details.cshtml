@model Tag
@{
    ViewData["Title"] = Model.Name;
}
<h1 class="text-2xl font-bold text-gray-900">#@Model.Name</h1>
<dl class="mt-4 grid gap-2 text-sm sm:grid-cols-[10rem_1fr]">
    <dt class="text-gray-500">Color</dt><dd class="font-mono">@Model.ColorHex</dd>
    <dt class="text-gray-500">Linked tasks</dt>
    <dd>
        <ul class="m-0 list-disc ps-5">
            @foreach (var link in Model.TaskTags)
            {
                <li>
                    <a class="text-indigo-600 hover:underline" asp-controller="Tasks" asp-action="Details" asp-route-id="@link.TaskItemId">@(link.TaskItem?.Title ?? link.TaskItemId.ToString())</a>
                </li>
            }
        </ul>
    </dd>
</dl>
