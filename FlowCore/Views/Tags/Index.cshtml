@model IReadOnlyList<TagListRow>
@{
    ViewData["Title"] = "Tags";
}
<h1 class="text-3xl font-bold tracking-tight text-fg">Tags</h1>
<p class="mt-2 text-fg-secondary">Labels used on tasks.</p>

<div class="mt-8 flex flex-wrap gap-3">
    @foreach (var row in Model)
    {
        <a asp-controller="Tags" asp-action="Details" asp-route-id="@row.Id"
           class="inline-flex items-center gap-2 rounded-xl border border-fg-muted/15 bg-card px-4 py-3 shadow-card transition-colors duration-150 hover:border-brand/35 hover:bg-raised">
            <span class="h-3 w-3 rounded-full border border-fg-muted/30" style="background-color: @row.ColorHex"></span>
            <span class="font-medium text-fg">@row.Name</span>
        </a>
    }
</div>
