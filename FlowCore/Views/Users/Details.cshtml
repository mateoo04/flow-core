@model FlowCore.Models.User
@{
    ViewData["Title"] = Model.FullName;
}
<h1 class="text-3xl font-bold tracking-tight text-fg">@Model.FullName</h1>
<dl class="mt-6 grid gap-3 text-sm sm:grid-cols-[8rem_1fr]">
    <dt class="text-fg-muted">Email</dt><dd class="text-fg">@Model.Email</dd>
    <dt class="text-fg-muted">Joined</dt><dd class="text-fg-secondary">@Model.JoinedAt.ToString("u")</dd>
    <dt class="text-fg-muted">Assignments</dt><dd class="text-fg-secondary">@Model.TaskAssignments.Count</dd>
</dl>
