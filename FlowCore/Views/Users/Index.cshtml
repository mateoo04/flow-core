@model IReadOnlyList<UserListRow>
@{
    ViewData["Title"] = "Users";
}
<h1 class="text-2xl font-bold text-gray-900">Users</h1>
<table class="mt-4 w-full border-collapse border border-gray-200 text-left text-sm">
    <thead class="bg-gray-50">
    <tr>
        <th class="border-b border-gray-200 px-3 py-2">Name</th>
        <th class="border-b border-gray-200 px-3 py-2">Email</th>
        <th class="border-b border-gray-200 px-3 py-2">Active</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var row in Model)
    {
        <tr class="border-b border-gray-100">
            <td class="px-3 py-2">
                <a class="text-indigo-600 hover:underline" asp-controller="Users" asp-action="Details" asp-route-id="@row.Id">@row.FullName</a>
            </td>
            <td class="px-3 py-2">@row.Email</td>
            <td class="px-3 py-2">@row.IsActive</td>
        </tr>
    }
    </tbody>
</table>
