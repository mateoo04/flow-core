@model IReadOnlyList<CommentListRow>
@{
    ViewData["Title"] = "Comments";
}
<h1 class="text-2xl font-bold text-gray-900">Comments</h1>
<table class="mt-4 w-full border-collapse border border-gray-200 text-left text-sm">
    <thead class="bg-gray-50">
    <tr>
        <th class="border-b border-gray-200 px-3 py-2">When</th>
        <th class="border-b border-gray-200 px-3 py-2">Author task</th>
        <th class="border-b border-gray-200 px-3 py-2">Preview</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var row in Model)
    {
        <tr class="border-b border-gray-100">
            <td class="px-3 py-2">@row.CreatedAt.ToString("u")</td>
            <td class="px-3 py-2">
                <a class="text-indigo-600 hover:underline" asp-controller="Comments" asp-action="Details" asp-route-id="@row.Id">@row.AuthorName</a>
                <span class="text-gray-500"> · </span>
                <a class="text-indigo-600 hover:underline" asp-controller="Tasks" asp-action="Details" asp-route-id="@row.TaskItemId">Task</a>
            </td>
            <td class="px-3 py-2 max-w-md">@row.BodyPreview</td>
        </tr>
    }
    </tbody>
</table>
