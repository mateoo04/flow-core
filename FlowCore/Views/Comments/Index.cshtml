@model IReadOnlyList<CommentListRow>
@{
    ViewData["Title"] = "Comments";
}
<h1 class="text-3xl font-bold tracking-tight text-fg">Comments</h1>
<p class="mt-2 text-fg-secondary">Activity feed (read-only).</p>

<div class="mt-8 flex flex-col gap-4">
    @foreach (var row in Model)
    {
        <article class="rounded-xl border border-fg-muted/10 bg-card p-4 shadow-card">
            <div class="flex flex-wrap items-center justify-between gap-2 text-xs text-fg-muted">
                <span class="font-medium text-fg-secondary">@row.AuthorName</span>
                <time datetime="@row.CreatedAt.ToString("O")">@row.CreatedAt.ToString("g")</time>
            </div>
            <p class="mt-2 text-sm text-fg-secondary">@row.BodyPreview</p>
            <div class="mt-3 flex flex-wrap gap-3 text-xs">
                <a class="rounded text-brand outline-none hover:text-fg focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-card"
                   asp-controller="Comments" asp-action="Details" asp-route-id="@row.Id"
                   aria-label="Open full comment by @row.AuthorName">Open comment</a>
                <a class="rounded text-brand outline-none hover:text-fg focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-card"
                   asp-controller="Tasks" asp-action="Details" asp-route-id="@row.TaskItemId">Open related task</a>
            </div>
        </article>
    }
</div>
