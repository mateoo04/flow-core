@model Comment
@{
    ViewData["Title"] = "Comment";
}
<h1 class="text-2xl font-bold text-gray-900">Comment</h1>
<dl class="mt-4 grid gap-2 text-sm sm:grid-cols-[10rem_1fr]">
    <dt class="text-gray-500">Task</dt>
    <dd>
        <a class="text-indigo-600 hover:underline" asp-controller="Tasks" asp-action="Details" asp-route-id="@Model.TaskItemId">Open task</a>
    </dd>
    <dt class="text-gray-500">Created</dt><dd>@Model.CreatedAt.ToString("u")</dd>
    <dt class="text-gray-500">Body</dt><dd class="whitespace-pre-wrap">@Model.Body</dd>
</dl>
