@model FlowCore.Models.ViewModels.SettingsIndexVm
@inject FlowCore.Services.UiText T
@{
    ViewData["Title"] = "Settings";
    var error = TempData["SettingsError"] as string;
    var ws = Model.ActiveWorkspace;
    var statuses = Model.Statuses;
}
<div class="mb-10 flex flex-wrap items-end justify-between gap-4">
    <div class="min-w-0">
        <h1 class="font-headline mb-1 text-3xl font-extrabold tracking-tight text-fg">Settings</h1>
        <p class="text-sm font-medium text-fg-secondary">
            Task statuses for <span class="font-semibold text-fg">@ws.Name</span>. Each workspace defines its own workflow.
        </p>
    </div>
    @if (Model.AllWorkspaces.Count > 1)
    {
        <form method="get" asp-action="Index" class="flex items-center gap-2">
            <label for="workspace-picker" class="text-xs font-semibold uppercase tracking-wider text-fg-muted">Workspace</label>
            <select id="workspace-picker" name="workspaceId" onchange="this.form.submit()"
                    class="rounded-full border border-border bg-[var(--color-surface)] px-4 py-2 text-sm font-semibold text-fg focus:border-[var(--color-secondary)] focus:outline-none focus:ring-1 focus:ring-[var(--color-secondary)]">
                @foreach (var w in Model.AllWorkspaces)
                {
                    <option value="@w.Id" selected="@(w.Id == ws.Id)">@w.Name</option>
                }
            </select>
        </form>
    }
</div>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="mb-6 rounded-2xl border border-[var(--color-error)]/40 bg-[var(--color-error)]/10 px-5 py-3 text-sm text-fg">
        @error
    </div>
}

<section aria-labelledby="statuses-heading" class="space-y-4">
    <div class="flex items-center gap-3">
        <h2 id="statuses-heading" class="font-headline text-lg font-bold tracking-tight text-fg">Task statuses</h2>
        <span class="rounded-md bg-[var(--color-primary)]/10 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-fg-secondary">@statuses.Count</span>
    </div>

    @if (statuses.Count == 0)
    {
        <p class="rounded-2xl border border-dashed border-border bg-raised/20 p-10 text-center text-fg-muted">No statuses yet. Add one below.</p>
    }
    else
    {
        <ul class="space-y-3">
            @for (var i = 0; i < statuses.Count; i++)
            {
                var s = statuses[i];
                <li class="rounded-2xl border border-border bg-card p-4 shadow-sm">
                    <form method="post" asp-action="Update" asp-route-workspaceId="@ws.Id" asp-route-id="@s.Id" class="flex flex-wrap items-center gap-3">
                        @Html.AntiForgeryToken()
                        <span class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-border" style="background-color: @s.ColorHex" aria-hidden="true"></span>
                        <input type="text" name="Name" value="@s.Name" required
                               class="min-w-0 flex-1 rounded-lg border border-border bg-[var(--color-surface)] px-3 py-2 text-sm text-fg outline-none focus:border-[var(--color-secondary)] focus:ring-1 focus:ring-[var(--color-secondary)]"
                               aria-label="Status name"/>
                        <input type="text" name="ColorHex" value="@s.ColorHex"
                               class="w-28 rounded-lg border border-border bg-[var(--color-surface)] px-3 py-2 font-mono text-xs text-fg outline-none focus:border-[var(--color-secondary)] focus:ring-1 focus:ring-[var(--color-secondary)]"
                               aria-label="Status color hex"/>
                        <label class="inline-flex items-center gap-2 text-xs text-fg-secondary">
                            <input type="checkbox" name="IsDoneState" value="true" @(s.IsDoneState ? "checked" : "")/>
                            Done state
                        </label>
                        <span class="text-[10px] font-semibold uppercase tracking-wider text-fg-muted">@s.TaskItems.Count tasks</span>
                        <button type="submit" class="rounded-full border border-border bg-[var(--color-surface)] px-4 py-2 text-xs font-semibold text-fg transition-colors hover:bg-[var(--color-surface-container)]">Save</button>
                    </form>

                    <div class="mt-3 flex flex-wrap items-center gap-2">
                        <form method="post" asp-action="Reorder" asp-route-workspaceId="@ws.Id" asp-route-id="@s.Id" class="inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="direction" value="-1"/>
                            <button type="submit" @(i == 0 ? "disabled" : "")
                                    class="rounded-full border border-border bg-[var(--color-surface)] px-3 py-1.5 text-xs font-semibold text-fg-secondary transition-colors hover:bg-[var(--color-surface-container)] disabled:cursor-not-allowed disabled:opacity-40">
                                Move up
                            </button>
                        </form>
                        <form method="post" asp-action="Reorder" asp-route-workspaceId="@ws.Id" asp-route-id="@s.Id" class="inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="direction" value="1"/>
                            <button type="submit" @(i == statuses.Count - 1 ? "disabled" : "")
                                    class="rounded-full border border-border bg-[var(--color-surface)] px-3 py-1.5 text-xs font-semibold text-fg-secondary transition-colors hover:bg-[var(--color-surface-container)] disabled:cursor-not-allowed disabled:opacity-40">
                                Move down
                            </button>
                        </form>
                        <form method="post" asp-action="Delete" asp-route-workspaceId="@ws.Id" asp-route-id="@s.Id" class="inline" onsubmit="return confirm('Delete this status?');">
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    class="rounded-full border border-[var(--color-error)]/50 px-3 py-1.5 text-xs font-semibold text-[var(--color-error)] transition-colors hover:bg-[var(--color-error)]/10">
                                Delete
                            </button>
                        </form>
                    </div>
                </li>
            }
        </ul>
    }
</section>

<section aria-labelledby="add-status-heading" class="mt-10">
    <h2 id="add-status-heading" class="font-headline text-lg font-bold tracking-tight text-fg">Add status</h2>
    <form method="post" asp-action="Create" asp-route-workspaceId="@ws.Id" class="mt-4 space-y-3 rounded-2xl border border-border bg-card p-5 max-w-xl shadow-sm">
        @Html.AntiForgeryToken()
        <div>
            <label for="new-status-name" class="block text-xs font-semibold uppercase tracking-wider text-fg-muted">Name</label>
            <input id="new-status-name" type="text" name="Name" required
                   class="mt-1 w-full rounded-lg border border-border bg-[var(--color-surface)] px-3 py-2 text-sm text-fg outline-none focus:border-[var(--color-secondary)] focus:ring-1 focus:ring-[var(--color-secondary)]"/>
        </div>
        <div>
            <label for="new-status-color" class="block text-xs font-semibold uppercase tracking-wider text-fg-muted">Color (hex)</label>
            <input id="new-status-color" type="text" name="ColorHex" value="#94A3B8"
                   class="mt-1 w-full rounded-lg border border-border bg-[var(--color-surface)] px-3 py-2 font-mono text-sm text-fg outline-none focus:border-[var(--color-secondary)] focus:ring-1 focus:ring-[var(--color-secondary)]"/>
        </div>
        <label class="inline-flex items-center gap-2 text-sm text-fg-secondary">
            <input type="checkbox" name="IsDoneState" value="true"/>
            Mark as done state
        </label>
        <div>
            <button type="submit" class="flex items-center gap-2 rounded-full bg-[var(--color-secondary)] px-5 py-2 text-sm font-semibold text-[var(--color-on-secondary)] shadow-sm transition-opacity hover:opacity-95">
                <span class="material-symbols-outlined text-[18px]" aria-hidden="true">add</span>
                Add status
            </button>
        </div>
    </form>
</section>
