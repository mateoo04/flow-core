@model ProjectCreateFormVm
@inject FlowCore.Services.UiText T
@{
    ViewData["Title"] = T["crud.projects.create_title"];
    var workspaces = ViewBag.Workspaces as IReadOnlyList<Workspace> ?? Array.Empty<Workspace>();
}
<h1 class="text-3xl font-bold tracking-tight text-fg">@T["crud.projects.create_title"]</h1>
<form method="post" asp-action="Create" class="mt-8 max-w-xl space-y-5">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-sm text-brand-warn"></div>
    <div>
        <label asp-for="WorkspaceId" class="block text-sm font-medium text-fg-secondary">Organization</label>
        <select asp-for="WorkspaceId" class="mt-1 w-full rounded-lg border border-fg-muted/20 bg-app px-3 py-2 text-fg">
            @foreach (var w in workspaces)
            {
                <option value="@w.Id">@w.Name</option>
            }
        </select>
    </div>
    <div>
        <label asp-for="Name" class="block text-sm font-medium text-fg-secondary">Name</label>
        <input asp-for="Name" class="mt-1 w-full rounded-lg border border-fg-muted/20 bg-app px-3 py-2 text-fg" required/>
    </div>
    <div>
        <label asp-for="Description" class="block text-sm font-medium text-fg-secondary">Description</label>
        <textarea asp-for="Description" rows="4" class="mt-1 w-full rounded-lg border border-fg-muted/20 bg-app px-3 py-2 text-fg"></textarea>
    </div>
    <div>
        <label asp-for="Status" class="block text-sm font-medium text-fg-secondary">Status</label>
        <select asp-for="Status" asp-items="Html.GetEnumSelectList<ProjectStatus>()" class="mt-1 w-full rounded-lg border border-fg-muted/20 bg-app px-3 py-2 text-fg"></select>
    </div>
    <div>
        <label asp-for="Priority" class="block text-sm font-medium text-fg-secondary">Priority</label>
        <select asp-for="Priority" asp-items="Html.GetEnumSelectList<ProjectPriority>()" class="mt-1 w-full rounded-lg border border-fg-muted/20 bg-app px-3 py-2 text-fg"></select>
    </div>
    <div class="flex gap-3">
        <button type="submit" class="rounded-xl bg-brand px-4 py-2 text-sm font-semibold text-white">@T["crud.projects.create_submit"]</button>
        <a asp-action="Index" class="rounded-xl border border-fg-muted/20 px-4 py-2 text-sm text-fg-secondary">Cancel</a>
    </div>
</form>
