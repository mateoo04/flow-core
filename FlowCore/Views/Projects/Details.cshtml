@model Project
@{
    ViewData["Title"] = Model.Key;
    var defaultBoard = Model.Boards.FirstOrDefault(b => b.IsDefault) ?? Model.Boards.FirstOrDefault();
}
<header class="border-b border-fg-muted/15 pb-6">
    <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
            <p class="font-mono text-sm text-brand">@Model.Key</p>
            <h1 class="mt-1 text-3xl font-bold tracking-tight text-fg">@Model.Name</h1>
            <p class="mt-2 max-w-2xl text-fg-secondary">@Model.Description</p>
            <div class="mt-4 flex flex-wrap gap-2">
                <span class="rounded-full bg-raised px-3 py-1 text-xs font-medium text-fg-secondary">@Model.Status</span>
                <span class="rounded-full bg-raised px-3 py-1 text-xs text-fg-muted">Priority @Model.Priority</span>
            </div>
        </div>
        @if (defaultBoard is not null)
        {
            <a asp-controller="Boards" asp-action="Details" asp-route-id="@defaultBoard.Id"
               class="inline-flex items-center justify-center rounded-xl bg-brand px-5 py-2.5 text-sm font-semibold text-white shadow-card transition-colors duration-150 hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand">
                Open board
            </a>
        }
    </div>
    <div class="mt-4 text-sm">
        <a class="rounded text-brand outline-none transition-colors hover:text-fg focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-app" asp-controller="Workspaces" asp-action="Details" asp-route-id="@Model.WorkspaceId"><span aria-hidden="true">← </span>Workspace</a>
    </div>
</header>

@if (defaultBoard is null)
{
    <p class="mt-8 rounded-xl border border-dashed border-fg-muted/30 bg-card p-8 text-center text-fg-muted">No board on this project yet.</p>
}
else
{
    <p class="mt-6 text-sm text-fg-muted">Default board: <span class="text-fg-secondary">@defaultBoard.Name</span>. Use <strong>Open board</strong> for the full column view.</p>
}

<section class="mt-8">
    <h2 class="text-lg font-semibold text-fg">All boards</h2>
    <ul class="mt-3 flex flex-wrap gap-2">
        @foreach (var b in Model.Boards)
        {
            <li>
                <a class="rounded-lg border border-fg-muted/20 px-3 py-2 text-sm text-brand outline-none transition-colors hover:border-brand/40 hover:bg-raised focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-app"
                   asp-controller="Boards" asp-action="Details" asp-route-id="@b.Id">@b.Name</a>
            </li>
        }
    </ul>
</section>
