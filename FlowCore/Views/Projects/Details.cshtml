@model ProjectDetailsPageViewModel
@inject FlowCore.Services.UiText T
@{
    ViewData["Title"] = Model.Project.Name;
    var project = Model.Project;
    var activeBoard = Model.ActiveBoard;
}
<header class="border-b border-fg-muted/15 pb-6">
    <div class="flex flex-wrap items-start justify-between gap-4">
        <div class="min-w-0">
            <h1 class="text-3xl font-bold tracking-tight text-fg">@project.Name</h1>
            <p class="mt-2 max-w-2xl text-fg-secondary">@project.Description</p>
            <div class="mt-4 flex flex-wrap gap-2">
                <span class="rounded-full bg-raised px-3 py-1 text-xs font-medium text-fg-secondary">@project.Status</span>
                <span class="rounded-full bg-raised px-3 py-1 text-xs text-fg-muted">Priority @project.Priority</span>
            </div>
        </div>
        <div class="flex flex-wrap items-center gap-2">
            @if (activeBoard is not null)
            {
                <a class="rounded-xl border-2 border-brand px-3 py-2 text-sm font-semibold text-brand outline-none transition-colors hover:bg-brand/10"
                   asp-controller="Tasks" asp-action="Create" asp-route-projectId="@project.Id" asp-route-boardId="@activeBoard.Id">New task</a>
            }
            <a class="rounded-xl border border-fg-muted/20 px-3 py-2 text-sm text-fg-secondary hover:bg-raised"
               asp-controller="TaskStatusDefinitions" asp-action="Manage" asp-route-projectId="@project.Id">@T["crud.statuses.manage_link"]</a>
            <form method="post" asp-action="Delete" asp-route-id="@project.Id" class="inline" onsubmit="return confirm('Delete this project and all tasks?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="rounded-xl border border-brand-warn/40 px-3 py-2 text-sm font-medium text-brand-warn hover:bg-brand-warn/10">@T["crud.projects.delete"]</button>
            </form>
        </div>
    </div>
    <div class="mt-4 text-sm">
        <a class="rounded text-brand outline-none transition-colors hover:text-fg focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-app" asp-controller="Workspaces" asp-action="Details" asp-route-id="@project.WorkspaceId"><span aria-hidden="true">← </span>Organization</a>
    </div>
</header>

@if (Model.BoardsOrdered.Count == 0)
{
    <p class="mt-8 rounded-xl border border-dashed border-fg-muted/30 bg-card p-8 text-center text-fg-muted">No board on this project yet.</p>
}
else
{
    <div class="mt-6 flex flex-wrap gap-1 border-b border-fg-muted/15 pb-px" role="tablist" aria-label="Boards">
        @foreach (var b in Model.BoardsOrdered)
        {
            var isActive = Model.ActiveBoard?.Id == b.Id;
            <a role="tab"
               aria-selected="@(isActive ? "true" : "false")"
               class="rounded-t-lg px-4 py-2.5 text-sm font-medium transition-colors duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand @(isActive ? "border-b-2 border-brand bg-raised/60 text-fg" : "text-fg-secondary hover:bg-raised/40 hover:text-fg")"
               asp-controller="Projects" asp-action="Details" asp-route-id="@project.Id" asp-route-boardId="@b.Id">@b.Name</a>
        }
    </div>

    @if (Model.ActiveBoard is { } board)
    {
        <partial name="_BoardKanban" model="board"/>
    }
}
