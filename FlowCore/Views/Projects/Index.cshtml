@model IReadOnlyList<ProjectListRow>
@inject FlowCore.Services.UiText T
@{
    ViewData["Title"] = "Projects";
    var filterWs = ViewBag.FilterWorkspaceId as Guid?;
}
<div class="mb-8 flex flex-wrap items-end justify-between gap-4">
    <div class="min-w-0">
        <h1 class="font-headline mb-1 text-3xl font-extrabold tracking-tight text-fg">Projects</h1>
        <p class="text-sm font-medium text-fg-secondary">Open a project to see its board and work breakdown.</p>
    </div>
    <a class="flex items-center gap-2 rounded-full bg-[var(--color-secondary)] px-4 py-2 text-sm font-semibold text-white shadow-sm transition-opacity hover:opacity-95"
       asp-action="Create" asp-route-workspaceId="@filterWs">
        <span class="material-symbols-outlined text-[18px]" aria-hidden="true">add</span>
        @T["crud.projects.create_title"]
    </a>
</div>
@if (filterWs is { } wsId)
{
    <div class="mt-3 inline-flex items-center gap-2 rounded-full bg-raised px-3 py-1 text-sm text-fg-secondary">
        <span>Organization filter</span>
        <span class="font-mono text-xs text-fg-muted">@wsId</span>
        <a class="ml-2 rounded text-brand outline-none hover:text-fg focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 focus-visible:ring-offset-raised" asp-action="Index">Clear filter</a>
    </div>
}
<div class="flex flex-col gap-3">
    @foreach (var row in Model.OrderBy(r => r.Name))
    {
        <a asp-controller="Projects" asp-action="Details" asp-route-id="@row.Id"
           class="group flex items-center justify-between gap-4 rounded-xl border-l-4 border-[var(--color-secondary)] bg-card px-5 py-4 shadow-sm transition-all duration-200 hover:shadow-xl hover:shadow-[var(--color-primary)]/5 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-secondary)]">
            <div class="min-w-0">
                <div class="truncate font-headline text-base font-bold text-fg">@row.Name</div>
            </div>
            <div class="flex shrink-0 items-center gap-3">
                <span class="rounded px-2 py-1 text-[10px] font-bold uppercase tracking-widest text-[var(--color-secondary)] bg-[var(--color-secondary)]/10">@row.Status</span>
                <span class="material-symbols-outlined text-[18px] text-fg-muted transition-transform group-hover:translate-x-0.5" aria-hidden="true">arrow_forward</span>
            </div>
        </a>
    }
</div>
