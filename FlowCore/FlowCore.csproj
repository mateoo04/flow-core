<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
    </PropertyGroup>

    <ItemGroup>
        <Content Update="locales\en.default.json">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
    </ItemGroup>

    <!-- Keeps wwwroot/css/tailwind.css in sync when building from Rider/VS (requires Node + npm install at repo root). -->
    <Target Name="TailwindBuild" BeforeTargets="BeforeBuild" Condition="Exists('$(MSBuildProjectDirectory)\..\package.json')">
        <Exec WorkingDirectory="$(MSBuildProjectDirectory)\.." Command="npm run build:css" ContinueOnError="true"/>
    </Target>

</Project>
